NODE_ENV=production
PORT=3000

# PostgreSQL (Railway / Supabase / o'z serveringiz)
DB_HOST=your-db-host.railway.app
DB_PORT=5432
DB_NAME=anthology_db
DB_USER=postgres
DB_PASSWORD=your_strong_password

# JWT — kamida 32 ta tasodifiy belgi
JWT_ACCESS_SECRET=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (media fayllar uchun)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-anthology-bucket
